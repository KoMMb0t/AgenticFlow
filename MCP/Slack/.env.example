# Slack MCP Server — Umgebungsvariablen
# Kopiere diese Datei zu ".env" und trage echte Werte ein. NIEMALS committen!

# Bot-Token (xoxb-...) aus https://api.slack.com/apps -> deine App -> OAuth & Permissions
# Benötigte Bot Token Scopes: chat:write, channels:read, channels:history, groups:read, users:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
