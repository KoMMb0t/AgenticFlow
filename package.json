{
  "name": "agentic-flow",
  "version": "0.1.0",
  "description": "AgenticFlow — Multi-Agent Desktop Hub with Claude Architect, cloud connectors, and Perfect Memory",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "node tests/test.js"
  },
  "keywords": [
    "electron",
    "multi-account",
    "connector",
    "manager",
    "desktop"
  ],
  "author": "KI Assi (Mende) / KoMMb0t",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "electron-store": "^8.1.0",
    "node-fetch": "^3.3.2",
    "express": "^4.18.2",
    "body-parser": "^1.20.2"
  },
  "build": {
    "appId": "com.kommuniverse.multi-account-connector-builder",
    "productName": "Multi-Account Connector Builder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
